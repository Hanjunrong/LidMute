{
  "manifest_version": 3,
  "name": "LidMute Chrome Monitor",
  "version": "0.1.0",
  "minimum_chrome_version": "105",
  "description": "Records audible Chrome tabs for LidMute.",
  "permissions": ["tabs", "nativeMessaging", "storage"],
  "background": {
    "service_worker": "service-worker.mjs",
    "type": "module"
  }
}
